{
  "$schema": "https://dprint.dev/schemas/v0.json",
  "projectType": "open",
  "incremental": true,
  "useAdditionalBuiltinPlugins": true,
  "plugins": [
    "https://plugins.dprint.dev/typescript-0.91.3.wasm",
    "https://plugins.dprint.dev/json-0.19.4.wasm",
    "https://plugins.dprint.dev/markdown-0.17.8.wasm",
    "https://plugins.dprint.dev/toml-0.6.2.wasm"
  ],
  "includes": [
    "**/*.{ts,mts,js,mjs,json,md,toml,yml,yaml}",
    "*.json"
  ],
  "excludes": [
    "**/target",
    "**/node_modules",
    "**/ABSORBED-FROM",
    "**/*.lock"
  ],
  "typescript": {
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": "always",
    "quoteStyle": "alwaysDouble",
    "trailingCommas": "onlyMultiLine"
  },
  "json": {
    "lineWidth": 100,
    "indentWidth": 2
  },
  "markdown": {
    "lineWidth": 100,
    "textWrap": "always"
  },
  "toml": {
    "lineWidth": 100,
    "indentWidth": 2
  }
}
