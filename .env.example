# Configra environment template (no secrets — copy to .env locally)
# See docs/deploy.md for production guidance.

# ------------------------------------------------------------------------------
# Logging / tracing
# ------------------------------------------------------------------------------
CONFIGRA_LOG_LEVEL=info
CONFIGRA_LOG_FORMAT=pretty
# RUST_LOG=info,configra_ops=debug

# ------------------------------------------------------------------------------
# Correlation
# ------------------------------------------------------------------------------
# CONFIGRA_CORRELATION_ID=
CONFIGRA_CORRELATION_ID_HEADER=X-Correlation-ID

# ------------------------------------------------------------------------------
# Metrics
# ------------------------------------------------------------------------------
CONFIGRA_METRICS_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ------------------------------------------------------------------------------
# Health probes
# ------------------------------------------------------------------------------
CONFIGRA_HEALTHCHECK_TIMEOUT_SECS=5

# ------------------------------------------------------------------------------
# Graceful shutdown
# ------------------------------------------------------------------------------
CONFIGRA_SHUTDOWN_TIMEOUT_SECS=30

# ------------------------------------------------------------------------------
# Settly / pheno-config (consumer examples — no real credentials)
# ------------------------------------------------------------------------------
# PHENO_SERVICE_URL=http://localhost:8080
# PHENO_SERVICE_PORT=8080
# PHENO_SERVICE_LOG_LEVEL=info
# PHENO_SERVICE_DB_PATH=./data/config.db
