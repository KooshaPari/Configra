# EditorConfig — https://editorconfig.org
# Top-level config; per-language blocks follow.

root = true

[*]
charset                  = utf-8
end_of_line              = lf
indent_style             = space
indent_size              = 4
insert_final_newline     = true
trim_trailing_whitespace = true
max_line_length          = 100

[*.{yml,yaml,toml,json}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
max_line_length          = off

[*.{rs,py,go,ts,tsx,js,jsx}]
max_line_length = 100

[*.rs]
indent_size = 4

[Makefile]
indent_style = tab

[*.{sh,bash,zsh}]
indent_size = 2

[*.nix]
indent_size = 2

[*.{diff,patch}]
trim_trailing_whitespace = false
insert_final_newline     = false